<!--
        IMPORTANT:
        - Policy elements can appear only within the <inbound>, <outbound>, <backend> section elements.
        - To apply a policy to the incoming request (before it is forwarded to the backend service), place a corresponding policy element within the <inbound> section element.
        - To apply a policy to the outgoing response (before it is sent back to the caller), place a corresponding policy element within the <outbound> section element.
        - To add a policy, place the cursor at the desired insertion point and select a policy from the sidebar.
        - To remove a policy, delete the corresponding policy statement from the policy document.
        - Position the <base> element within a section element to inherit all policies from the corresponding section element in the enclosing scope.
        - Remove the <base> element to prevent inheriting policies from the corresponding section element in the enclosing scope.
        - Policies are applied in the order of their appearance, from the top down.
        - Comments within policy elements are not supported and may disappear. Place your comments between policy elements or at a higher level scope.
    -->
<policies>
    <inbound>
        <set-header name="RequestId" exists-action="override">
            <value>@(context.Request.Headers.GetValueOrDefault("x-aia-request-id",""))</value>
        </set-header>
        <!--+++++++++++++++++++++++++++++++++-->
        <!-- Start : Set CORS - TemplateRest -->
        <cors>
            <allowed-origins>
                <origin>*</origin>
            </allowed-origins>
            <allowed-methods preflight-result-max-age="1000">
                <method>*</method>
            </allowed-methods>
            <allowed-headers>
                <header>*</header>
            </allowed-headers>
            <expose-headers>
                <header>*</header>
            </expose-headers>
        </cors>
        <!-- End : Set CORS - TemplateRest -->
        <!--+++++++++++++++++++++++++++++++-->
        <!--+++++++++++++++++++++++++++++++++++-->
        <rate-limit calls="{{rateLimit-per-category}}" renewal-period="60" remaining-calls-variable-name="remainingCallsPerSubscription" />
        <!--+++++++++++++++++++++++++++++++-->
        <!-- Start : validate token header -->
        <set-variable name="appId-all" value="{{appId-all}}" />
        <choose>
            <when condition="@(!context.Request.Headers.ContainsKey("Authorization"))">
                <return-response>
                    <set-status code="401" reason="Unauthorized" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>@{
                        JObject resBody = new JObject(
                            new JProperty("reasonCode", "ERR_GW_401"),
                            new JProperty("reason", "Unauthorized"),
                            new JProperty("message", "Authorization error"),
                            new JProperty("sourceSystem", "Gateway")
                        );
                        return resBody.ToString();
                    }</set-body>
                </return-response>
            </when>
        </choose>
        <choose>
            <when condition="@(context.Request.Headers.ContainsKey("Authorization"))">
                <cache-lookup-value key="@{
                        String accessToken = (String)context.Request.Headers.GetValueOrDefault("Authorization", "");
                        String subscription = (String)context.Request.Headers.GetValueOrDefault("x-aia-apikey", "");
                        String cacheKey = "api[TokenManager]__subscription["+subscription+"]__accessToken["+accessToken+"]";
                        return cacheKey;
                    }" variable-name="appId" caching-type="internal" />
                <choose>
                    <when condition="@{
                        String auth = context.Request.Headers.GetValueOrDefault("Authorization", "");
                        if (auth.StartsWith("Bearer ")) {
                            String token = auth.Substring("Bearer ".Length);
                            // Check if it looks like a JWT (has 2 dots and starts with "ey")
                            return token.Split('.').Length == 3 && token.StartsWith("ey");
                        }
                        return false;
                    }">
                        <validate-jwt header-name="Authorization"
                            failed-validation-httpcode="401"
                            require-expiration-time="false"
                            require-scheme="Bearer">
                            <openid-config url="https://login.microsoftonline.com/8b6909d5-3e9a-4e05-a3f0-2cb7537cf4be/v2.0/.well-known/openid-configuration" />
                            <issuers>
                                <issuer>https://sts.windows.net/8b6909d5-3e9a-4e05-a3f0-2cb7537cf4be/</issuer>
                            </issuers>
                        </validate-jwt>
                    </when>
                    <when condition="@{
                        try{
                            if(!context.Variables.ContainsKey("appId")){
                                return true;
                            }

                            String appIdAll = (String) context.Variables["appId-all"];
                            JArray permissionAppId = JArray.Parse(appIdAll);

                            if (permissionAppId.Count == 0) {
                                return true;
                            }

                            String appIdMain = (String) permissionAppId[0];
 
                            JArray appIdList = (JArray) context.Variables["appId"];
                            for(int i=0; i<appIdList.Count; i++){                          
                                if( appIdMain.Equals((String) appIdList[i]) ) {
                                    return false;
                                }
                            }
                           
                            return true;
                        } catch(Exception err){
                            return true;
                        }
                    }">
                        <return-response>
                            <set-status code="401" reason="Unauthorized" />
                            <set-header name="Content-Type" exists-action="override">
                                <value>application/json</value>
                            </set-header>
                            <set-body>@{
                                JObject resBody = new JObject(
                                    new JProperty("reasonCode", "ERR_GW_401"),
                                    new JProperty("reason", "Unauthorized"),
                                    new JProperty("message", "Authorization error"),
                                    new JProperty("sourceSystem", "Gateway")
                                );
                                return resBody.ToString();
                            }</set-body>
                        </return-response>
                    </when>
                </choose>
            </when>
        </choose>
        <!-- End : validate token header -->
        <!--+++++++++++++++++++++++++++++-->
        <!--+++++++++++++++++++++-->
        <!-- Start : check token -->
        <!-- <choose>
            <when condition="@(context.Request.Headers.ContainsKey("Authorization"))">
                <validate-jwt header-name="Authorization" failed-validation-httpcode="401" require-expiration-time="false" require-scheme="Bearer">
                    <openid-config url="https://login.microsoftonline.com/8b6909d5-3e9a-4e05-a3f0-2cb7537cf4be/v2.0/.well-known/openid-configuration" />
                    <issuers>
                        <issuer>https://sts.windows.net/8b6909d5-3e9a-4e05-a3f0-2cb7537cf4be/</issuer>
                    </issuers>
                </validate-jwt>
            </when>
        </choose> -->
        <!-- End : check token -->
        <!--+++++++++++++++++++-->
        <base />
        <!-- <set-backend-service backend-id="firestorm-Backend" /> -->
        <!-- <rewrite-uri template="@($"/firestorm{(string)context.Operation.UrlTemplate}")" /> --> 
    </inbound>
    <backend>
        <!--++++++++++++++++++++++++++++++++++++-->
        <!-- Start : Set timeout - TemplateRest -->
        <forward-request timeout="{{default-timeout-medium}}" />
        <!-- End : Set timeout - TemplateRest -->
        <!--++++++++++++++++++++++++++++++++++-->
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
        <!--++++++++++++++++++++++++++++++++++++++++++-->
        <!-- Start : Set error respose - TemplateRest -->
        <return-response>
            <set-status code="@(context.Response.StatusCode)" reason="@(context.LastError.Reason)" />
            <set-header name="Access-Control-Allow-Credentials" exists-action="override">
                <value>true</value>
            </set-header>
            <set-header name="Access-Control-Allow-Headers" exists-action="override">
                <value>*</value>
            </set-header>
            <set-header name="Access-Control-Allow-Origin" exists-action="override">
                <value>*</value>
            </set-header>
            <set-header name="Content-Type" exists-action="override">
                <value>application/json</value>
            </set-header>
            <set-body>@{
                JObject body = new JObject();
                body.Add(new JProperty("reasonCode", "ERR_GW_" + context.Response.StatusCode));
                body.Add(new JProperty("reason", (String) context.LastError.Reason));
                body.Add(new JProperty("message", (String) context.LastError.Message));
                body.Add(new JProperty("sourceSystem", "Gateway"));
                return body.ToString();
            }</set-body>
        </return-response>
        <!-- End : Set error respose - TemplateRest -->
        <!--++++++++++++++++++++++++++++++++++++++++-->
    </on-error>
</policies>
