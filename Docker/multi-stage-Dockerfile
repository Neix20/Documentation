FROM node:12 AS build
# FROM --platform=linux/amd64 node:12 AS build

# Create app directory
WORKDIR /usr/src

# Install app dependencies
# A wildcard is used to ensure both package.json AND package-lock.json are copied where available (npm@5+)
COPY package.json ./

RUN npm install
# If you are building your code for production
# RUN npm ci --only=production

# Bundle app source
COPY . .

RUN npm run build

# production environment
FROM nginx:1-alpine

RUN chown -R 1000:1000 /var/cache/nginx && \
        chown -R 1000:1000 /var/log/nginx && \
        chown -R 1000:1000 /etc/nginx/conf.d
RUN chmod -R 777 /etc/nginx/conf.d

COPY --from=build --chown=1000:1000 /usr/src/dist /usr/share/nginx/html
COPY --from=build --chown=1000:1000 /usr/src/nginx/nginx.conf /etc/nginx/nginx.conf
COPY --from=build --chown=1000:1000 /usr/src/nginx/default.conf /etc/nginx/conf.d/default.conf

USER 1000
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
